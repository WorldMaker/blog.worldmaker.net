---
layout: page.vto
---

<dl class="content">
{{ set lastDate = null }}
{{ for post of search.pages(`type=post ${tag}`, 'date=desc') }}
      {{ set date = new Date(post.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) }}
      {{ if lastDate != date }}
        <dt>{{ date }}</dt>
        {{ set lastDate = date }}
      {{ /if }}
    <dd><a href="{{ post.url }}">{{ post.title }}</a></dd>
{{ /for }}
</dl>
